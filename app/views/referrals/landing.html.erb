<% content_for(:title) { "Join #{@studio.name}" } %>

<div class="schedule-page">

  <%# ── Header ── %>
  <div class="schedule-header">
    <% if @brand&.logo_url.present? %>
      <img src="<%= @brand.logo_url %>" alt="<%= @studio.name %>" style="max-width: 80px; margin-bottom: 0.75rem; border-radius: 0.5rem;">
    <% end %>
    <h1 class="schedule-title">You've been invited!</h1>
    <p class="schedule-subtitle">
      <strong><%= @referrer.first_name || "Your friend" %></strong> wants you to join
      <strong><%= @studio.name %></strong>.
    </p>
  </div>

  <section class="dashboard-section">
    <div class="reward-card" style="text-align: center;">
      <div class="reward-name" style="font-size: 2rem;">50% off</div>
      <p class="reward-description">for both of you after your first visit</p>
    </div>
  </section>

  <section class="dashboard-section pb-5" style="text-align: center;">
    <%= link_to studio_landing_path(studio_slug: @studio.slug), class: "btn-book", style: "display: inline-block;" do %>
      Get Started <i class="fa fa-arrow-right"></i>
    <% end %>
  </section>

</div>
