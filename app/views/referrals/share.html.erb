<% content_for(:title) { "Share Referral — #{@studio.name}" } %>

<div class="schedule-page" data-controller="share"
     data-share-url-value="<%= @referral_url %>"
     data-share-title-value="Join me at <%= @studio.name %>!"
     data-share-text-value="<%= @referrer_name = current_user.first_name || 'Your friend' %> invited you to <%= @studio.name %>. Sign up and you both get 50%% off!">

  <%# ── Header ── %>
  <div class="schedule-header">
    <p class="schedule-studio-name"><%= @studio.name %></p>
    <h1 class="schedule-title">Invite a Friend</h1>
    <p class="schedule-subtitle">Share this link and you'll both get 50% off when your friend completes their first visit.</p>
  </div>

  <section class="dashboard-section">
    <p class="section-title">Your Referral Link</p>

    <div class="dashboard-card" style="text-align: center; padding: 1.5rem;">
      <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
        <input type="text" value="<%= @referral_url %>" readonly
               style="flex: 1; padding: 0.75rem; border: 1.5px solid rgba(43,33,24,0.15); border-radius: 0.75rem; font-size: 0.875rem; background: var(--oat, #F6F1EB);"
               data-share-target="urlField">
        <button data-action="click->share#copy" class="btn-redeem" style="border-radius: 0.75rem;">
          Copy
        </button>
      </div>

      <button data-action="click->share#nativeShare" class="btn-book" style="width: 100%;">
        <i class="fa fa-share-alt"></i> Share via...
      </button>
    </div>
  </section>

  <section class="dashboard-section pb-5">
    <div class="dashboard-card" style="text-align: center;">
      <p style="font-size: 0.875rem; color: rgba(43,33,24,0.5); margin: 0;">
        You have <%= current_user.referrals.active.count %> / 5 active referral links.
      </p>
    </div>

    <div style="text-align: center; margin-top: 1rem;">
      <%= link_to studio_landing_path(studio_slug: @studio.slug), class: "btn-secondary-action" do %>
        <i class="fa fa-arrow-left"></i> Back to Studio
      <% end %>
    </div>
  </section>

</div>
