<% content_for :title, "Reward History — #{@studio.name}" %>

<div class="schedule-page">

  <%# ── Header ── %>
  <div class="schedule-header">
    <p class="schedule-studio-name"><%= @studio.name %></p>
    <h1 class="schedule-title">Reward History</h1>
  </div>

  <section class="dashboard-section">
    <p class="section-title">Your Redemptions</p>

    <% if @reward_redemptions.any? %>
      <div class="dashboard-card">
        <% @reward_redemptions.each do |redemption| %>
          <div class="activity-row">
            <div class="activity-icon">
              <i class="fa fa-gift"></i>
            </div>
            <div class="activity-details">
              <div class="activity-title"><%= redemption.reward.name %></div>
              <div class="activity-subtitle">
                Code: <span style="font-weight: 600;"><%= redemption.code %></span>
                &middot;
                <%= redemption.redeemed_at&.strftime("%b %-d, %Y") %>
              </div>
            </div>
            <%= link_to "View",
                  reward_redemption_path(studio_slug: @studio.slug, id: redemption.id),
                  class: "btn-claim" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="dashboard-card">
        <div class="empty-state">
          <i class="fa fa-gift"></i>
          <p>You haven't redeemed any rewards yet.</p>
        </div>
      </div>
    <% end %>
  </section>

  <section class="dashboard-section pb-5">
    <div class="dashboard-card" style="text-align: center;">
      <%= link_to rewards_path(studio_slug: @studio.slug), class: "btn-secondary-action" do %>
        <i class="fa fa-arrow-left"></i> Back to Rewards
      <% end %>
    </div>
  </section>

</div>
