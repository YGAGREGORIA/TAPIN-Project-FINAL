<% content_for :title, "My Bookings — #{@studio.name}" %>

<div class="bookings-page">

  <%# ── Header ── %>
  <div class="bookings-header">
    <p class="schedule-studio-name"><%= @studio.name %></p>
    <h1 class="schedule-title">My Bookings</h1>
  </div>

  <%# ── Upcoming ── %>
  <div class="bookings-section">
    <p class="section-title">Upcoming</p>

    <% if @upcoming_bookings.any? %>
      <div class="dashboard-card p-0">
        <% @upcoming_bookings.each_with_index do |booking, i| %>
          <div class="booking-list-row <%= i > 0 ? 'booking-list-row--border' : '' %>">
            <div class="booking-date-block">
              <div class="booking-day"><%= booking.class_time.strftime("%-d") %></div>
              <div class="booking-month"><%= booking.class_time.strftime("%b") %></div>
            </div>

            <div class="booking-details">
              <div class="booking-class-name"><%= booking.class_name %></div>
              <div class="booking-studio-name">
                <%= booking.class_time.strftime("%-I:%M %p") %>
                <% if booking.studio_class&.teacher_name.present? %>
                  &middot; <%= booking.studio_class.teacher_name %>
                <% end %>
              </div>
            </div>

            <div class="booking-list-actions">
              <%= link_to booking_path(studio_slug: @studio.slug, id: booking.id),
                          class: "booking-view-link" do %>
                <i class="fa fa-chevron-right"></i>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="dashboard-card">
        <div class="empty-state">
          <i class="fa fa-calendar-o"></i>
          <p>No upcoming classes booked</p>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Book a class CTA ── %>
  <div class="bookings-cta">
    <%= link_to "Browse Class Schedule",
          classes_path(studio_slug: @studio.slug),
          class: "btn-book" %>
  </div>

  <%# ── Past bookings ── %>
  <% if @past_bookings.any? %>
    <div class="bookings-section">
      <p class="section-title">Past Classes</p>
      <div class="dashboard-card p-0">
        <% @past_bookings.each_with_index do |booking, i| %>
          <div class="booking-list-row booking-list-row--past <%= i > 0 ? 'booking-list-row--border' : '' %>">
            <div class="booking-date-block">
              <div class="booking-day"><%= booking.class_time.strftime("%-d") %></div>
              <div class="booking-month"><%= booking.class_time.strftime("%b") %></div>
            </div>

            <div class="booking-details">
              <div class="booking-class-name"><%= booking.class_name %></div>
              <div class="booking-studio-name">
                <%= booking.class_time.strftime("%-I:%M %p") %>
                <% if booking.studio_class&.teacher_name.present? %>
                  &middot; <%= booking.studio_class.teacher_name %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
