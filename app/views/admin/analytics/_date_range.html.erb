<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <ul class="nav nav-pills nav-fill">
      <li class="nav-item">
        <%= link_to "Overview", admin_analytics_path(start_date: params[:start_date], end_date: params[:end_date]),
              class: "nav-link #{'active' if action_name == 'show'}" %>
      </li>
      <li class="nav-item">
        <%= link_to "Points", points_admin_analytics_path(start_date: params[:start_date], end_date: params[:end_date]),
              class: "nav-link #{'active' if action_name == 'points'}" %>
      </li>
      <li class="nav-item">
        <%= link_to "Loyalty", loyalty_admin_analytics_path(start_date: params[:start_date], end_date: params[:end_date]),
              class: "nav-link #{'active' if action_name == 'loyalty'}" %>
      </li>
    </ul>
  </div>

  <%= form_with url: request.path, method: :get, class: "d-flex gap-2 align-items-center", data: { turbo_frame: "_top" } do |f| %>
    <%= f.date_field :start_date, value: @start_date.to_date, class: "form-control form-control-sm", style: "max-width: 160px;" %>
    <span class="text-muted">to</span>
    <%= f.date_field :end_date, value: @end_date.to_date, class: "form-control form-control-sm", style: "max-width: 160px;" %>
    <%= f.submit "Apply", class: "btn btn-outline-secondary btn-sm" %>
  <% end %>
</div>

<p class="text-muted mb-3" style="font-size: 0.85rem;"><%= @range_label %></p>
