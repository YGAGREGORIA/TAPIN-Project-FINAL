<!DOCTYPE html>
<html>
  <head>
    <title>TapIn Admin — <%= content_for(:title) || "Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="d-flex">
      <!-- Sidebar -->
      <nav class="bg-dark text-white p-3" style="width: 240px; min-height: 100vh;">
        <h5 class="mb-4">TapIn Admin</h5>
        <ul class="nav flex-column">
          <li class="nav-item">
            <%= link_to "Home", admin_dashboard_path, class: "nav-link text-white" %>
          </li>
          <li class="nav-item">
            <%= link_to "Members", admin_members_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "Deals", admin_deals_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "Rewards", admin_rewards_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "Mindbody", admin_mindbody_matches_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "Notifications", admin_notification_templates_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "Broadcasts", admin_broadcasts_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "Check-in Settings", admin_checkin_settings_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "Analytics", admin_analytics_path, class: "nav-link text-white-50" %>
          </li>
          <li class="nav-item">
            <%= link_to "AI Assistant", admin_assistant_path, class: "nav-link text-white-50" %>
          </li>
        </ul>
        <hr class="text-white-50">
        <small class="text-white-50"><%= current_studio&.name %></small>
        <% if user_signed_in? %>
          <div class="mt-3">
            <%= button_to "Log Out", destroy_user_session_path, method: :delete, class: "btn btn-outline-light btn-sm w-100" %>
          </div>
        <% end %>
      </nav>

      <!-- Main content -->
      <main class="flex-grow-1 p-4">
        <% if notice.present? %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= alert %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
