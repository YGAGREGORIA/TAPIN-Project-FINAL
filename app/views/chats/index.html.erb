<% content_for(:title) { "Your Conversations" } %>

<div class="schedule-page">

  <%# ── Header ── %>
  <div class="schedule-header">
    <h1 class="schedule-title">Your Conversations</h1>
    <p class="schedule-subtitle">Chat with your TapIn AI assistant</p>
  </div>

  <section class="dashboard-section">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <p class="section-title mb-0">Chats</p>
      <%= button_to chats_path, method: :post, class: "btn-redeem" do %>
        + New Chat
      <% end %>
    </div>

    <% if @chats.present? %>
      <% @chats.reverse.each do |chat| %>
        <%= link_to chat_path(chat), class: "dashboard-card d-flex gap-3 align-items-center mb-2", style: "text-decoration: none; color: inherit;" do %>
          <div class="chat-avatar-tapin">AI</div>
          <div style="flex: 1; min-width: 0;">
            <div class="d-flex justify-content-between">
              <span style="font-weight: 600; font-family: 'Space Grotesk', sans-serif;"><%= chat.title %></span>
              <span style="color: rgba(43,33,24,0.4); font-size: 0.8rem; flex-shrink: 0;"><%= time_ago_in_words(chat.updated_at) %> ago</span>
            </div>
            <% last_msg = chat.messages.order(created_at: :desc).first %>
            <p style="color: rgba(43,33,24,0.5); font-size: 0.875rem; margin: 0.25rem 0 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <%= last_msg ? truncate(last_msg.content, length: 80) : "No messages yet" %>
            </p>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="dashboard-card">
        <div class="empty-state">
          <div class="chat-avatar-tapin" style="width: 56px; height: 56px; font-size: 1rem; margin: 0 auto 1rem;">AI</div>
          <p>Start your first conversation</p>
          <p style="font-size: 0.875rem;">Ask about visits, rewards, classes, deals, and more.</p>
          <%= button_to chats_path, method: :post, class: "btn-book" do %>
            Start Chatting
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
</div>

<style>
  .chat-avatar-tapin {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--espresso-brown, #2B2118);
    color: var(--oat, #F6F1EB);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
    font-family: 'Space Grotesk', sans-serif;
    flex-shrink: 0;
  }
</style>
