<% content_for(:title) { @studio.name } %>

<div class="studio-landing" data-controller="nfc"
     data-nfc-studio-slug-value="<%= @studio.slug %>">

  <div class="studio-landing__header">
    <% if @brand&.logo_url.present? %>
      <img src="<%= @brand.logo_url %>" alt="<%= @studio.name %> logo" class="studio-landing__logo">
    <% end %>
    <h1 class="studio-landing__name"><%= @studio.name %></h1>
    <% if @brand&.tagline.present? %>
      <p class="studio-landing__tagline"><%= @brand.tagline %></p>
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="studio-landing__flash studio-landing__flash--notice"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="studio-landing__flash studio-landing__flash--alert"><%= alert %></div>
  <% end %>

  <div class="studio-landing__actions">
    <p class="studio-landing__welcome">Welcome! Enter your phone number to check in.</p>

    <%= form_with url: studio_checkin_path(studio_slug: @studio.slug), method: :post, class: "studio-landing__form" do |f| %>
      <div class="studio-landing__input-group">
        <%= f.telephone_field :phone, class: "studio-landing__input", placeholder: "e.g. 612345678", autofocus: true, inputmode: "tel" %>
        <%= f.submit "Check In", class: "studio-landing__button" %>
      </div>
    <% end %>

    <p class="studio-landing__hint">
      Tap your phone on the NFC tag or scan the QR code at reception.
    </p>

    <p class="studio-landing__signup">
      Don't have an account? <%= link_to "Sign up", new_user_registration_path, class: "studio-landing__link" %>
    </p>
  </div>

  <div class="studio-landing__nfc-status" data-nfc-target="status" style="display: none;">
  </div>
</div>

<% if @brand %>
<style>
  :root {
    --studio-primary: <%= @brand.primary_color || '#FF5733' %>;
    --studio-secondary: <%= @brand.secondary_color || '#33C1FF' %>;
    --studio-bg: <%= @brand.background_color || '#F5F5F5' %>;
    --studio-text: <%= @brand.text_color || '#222222' %>;
  }

  .studio-landing {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: var(--studio-bg);
    color: var(--studio-text);
    font-family: <%= @brand.font_body || 'system-ui, sans-serif' %>;
  }

  .studio-landing__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .studio-landing__logo {
    max-width: 120px;
    margin-bottom: 1rem;
  }

  .studio-landing__name {
    font-family: <%= @brand.font_heading || 'system-ui, sans-serif' %>;
    font-size: 2rem;
    color: var(--studio-primary);
    margin: 0;
  }

  .studio-landing__tagline {
    color: var(--studio-secondary);
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }

  .studio-landing__actions {
    text-align: center;
    max-width: 400px;
  }

  .studio-landing__form {
    margin-top: 1.5rem;
    width: 100%;
  }

  .studio-landing__input-group {
    display: flex;
    gap: 0.5rem;
  }

  .studio-landing__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 2px solid var(--studio-primary);
    border-radius: 8px;
    font-size: 1.1rem;
    text-align: center;
    outline: none;
  }

  .studio-landing__input:focus {
    border-color: var(--studio-secondary);
    box-shadow: 0 0 0 3px rgba(51, 193, 255, 0.2);
  }

  .studio-landing__button {
    padding: 0.75rem 1.5rem;
    background-color: var(--studio-primary);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
  }

  .studio-landing__button:hover {
    opacity: 0.9;
  }

  .studio-landing__signup {
    margin-top: 1.5rem;
    font-size: 0.875rem;
  }

  .studio-landing__link {
    color: var(--studio-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .studio-landing__hint {
    font-size: 0.875rem;
    opacity: 0.7;
    margin-top: 1rem;
  }

  .studio-landing__flash {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .studio-landing__flash--notice {
    background-color: #d4edda;
    color: #155724;
  }

  .studio-landing__flash--alert {
    background-color: #f8d7da;
    color: #721c24;
  }

  .studio-landing__nfc-status {
    margin-top: 1rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.875rem;
  }
</style>
<% end %>
