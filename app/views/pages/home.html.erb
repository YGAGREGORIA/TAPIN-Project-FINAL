<% content_for :title, "Welcome to Tapin" %>

<div class="schedule-page">
  <div class="schedule-header" style="padding-bottom: 2rem;">
    <h1 class="schedule-title" style="font-size: 2.25rem;">Welcome to Tapin</h1>
    <p class="schedule-subtitle">Track your classes, earn rewards, and discover deals at your favourite studios.</p>

    <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.5rem; width: 100%; max-width: 280px;">
      <% if user_signed_in? %>
        <%= link_to "Go to Dashboard", dashboard_path, class: "btn-book", style: "text-align: center;" %>
      <% else %>
        <%= link_to "Sign In", new_user_session_path, class: "btn-book", style: "text-align: center;" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "btn-secondary-action", style: "text-align: center;" %>
      <% end %>
    </div>
  </div>
</div>
