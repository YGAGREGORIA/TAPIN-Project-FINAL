<% content_for :title, "Rewards — #{@studio.name}" %>

<div class="schedule-page">

  <%# ── Header ── %>
  <div class="schedule-header">
    <p class="schedule-studio-name"><%= @studio.name %></p>
    <h1 class="schedule-title">Rewards</h1>
    <p class="schedule-subtitle">
      <%= current_user.current_visit_progress_for(@studio) %> / 10 visits toward your next reward
    </p>
  </div>

  <%# ── Stamp card ── %>
  <section class="dashboard-section">
    <p class="section-title">Your Progress</p>
    <div class="studio-progress-card">
      <% progress = current_user.current_visit_progress_for(@studio) %>
      <div class="stamp-card">
        <div class="stamp-grid">
          <% 10.times do |i| %>
            <div class="stamp <%= i < progress ? 'stamp--done' : '' %>">
              <% if i < progress %>
                <i class="fa fa-check"></i>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="stamp-card-footer">
          <div class="progress dashboard-progress">
            <div class="progress-bar" style="width: <%= (progress / 10.0 * 100).round %>%"></div>
          </div>
          <span class="stamp-count"><%= progress %> / 10</span>
        </div>
      </div>

      <% if current_user.free_class_reward_available_for?(@studio) %>
        <span class="reward-ready-badge">Reward ready!</span>
      <% else %>
        <div class="visits-remaining-text">
          <%= current_user.visits_remaining_for_next_reward(@studio) %>
          more <%= current_user.visits_remaining_for_next_reward(@studio) == 1 ? "visit" : "visits" %>
          to your next free class
        </div>
      <% end %>
    </div>
  </section>

  <%# ── Available Rewards ── %>
  <section class="dashboard-section">
    <p class="section-title">Available Rewards</p>
    <% if @rewards.any? %>
      <% @rewards.each do |reward| %>
        <div class="reward-card">
          <div class="reward-name"><%= reward.name %></div>
          <% if reward.description.present? %>
            <p class="reward-description"><%= reward.description %></p>
          <% end %>

          <% if reward.redeemable_by?(current_user) %>
            <%= button_to "Redeem Now",
                  redeem_reward_path(studio_slug: @studio.slug, id: reward.id),
                  method: :post,
                  class: "btn-redeem" %>
          <% else %>
            <p class="reward-description" style="opacity: 0.6;">
              Unlocks after 10 visits &middot; <%= current_user.visits_remaining_for_next_reward(@studio) %> remaining
            </p>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="dashboard-card">
        <div class="empty-state">
          <i class="fa fa-gift"></i>
          <p>No rewards available yet.</p>
        </div>
      </div>
    <% end %>
  </section>

  <%# ── History link ── %>
  <section class="dashboard-section pb-5">
    <div class="dashboard-card" style="text-align: center;">
      <%= link_to reward_redemptions_path(studio_slug: @studio.slug), class: "btn-secondary-action" do %>
        <i class="fa fa-history"></i> View Reward History
      <% end %>
    </div>
  </section>

</div>
